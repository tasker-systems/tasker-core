# Generated by Cargo
# will have compiled files and executables
debug
target
artifacts

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/


# Added by cargo

/target

# don't store the mcp file
.mcp.json

# don't store env files
.env
.env.test
.env.dev


# don't pay attention to tmp
tmp/

# Ruby extension build artifacts
*.bundle
*.so
*.dll
*.dylib
*.dSYM/
crates/tasker-rb/ext/*/Makefile
crates/tasker-rb/ext/*/mkmf.log
crates/tasker-rb/pkg/*/*.gem
crates/tasker-rb/pkg/*
crates/tasker-rb/*/*.gem
crates/tasker-rb/*.gem
crates/tasker-rb/spec/examples.txt

# no rspec results
rspec_results.json

# no log files
*.log

.pids/*
.logs/*

# Coverage reports (TAS-63)
coverage-reports/
*.profraw
*.profdata
crates/tasker-rb/coverage/
crates/tasker-py/.coverage
crates/tasker-py/htmlcov/
crates/tasker-ts/coverage/

# Python cache
__pycache__/
*.pyc

# uv virtual environments (coverage tooling)
cargo-make/scripts/coverage/.venv/

# FFI build artifacts
artifacts/

# Auto-generated CLAUDE.md files in subdirectories (keep only repo root)
CLAUDE.md
!/CLAUDE.md
